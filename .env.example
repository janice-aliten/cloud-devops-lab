# cloud-devops-lab — environment variable template
# Copy this file to .env and fill in values for local use
# NEVER commit a real .env file — it is blocked by .gitignore

# Application
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=info

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# AWS (only needed if running terraform plan or apply — not required for local lab)
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-key-here
# AWS_DEFAULT_REGION=ap-southeast-2
