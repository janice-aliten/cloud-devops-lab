# cloud-devops-lab — environment variable template

# Application
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=info

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
# Local lab defaults only. Do not reuse these values in production.
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=lab-admin
GRAFANA_ADMIN_PASSWORD=local-lab-password

# AWS
# Optional. Only needed if running terraform plan/apply locally.
# Not required for Docker Compose, GitHub Actions validation, or local monitoring lab.
# Never commit real AWS credentials.
# AWS_ACCESS_KEY_ID=REPLACE_WITH_LOCAL_PLACEHOLDER_ONLY
# AWS_SECRET_ACCESS_KEY=REPLACE_WITH_LOCAL_PLACEHOLDER_ONLY
# AWS_DEFAULT_REGION=ap-southeast-2