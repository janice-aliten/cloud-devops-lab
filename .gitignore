# Environment files — never commit real secrets
.env
.env.local
.env.*.local

# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/

# Logs — use samples/sanitized-app.log for demos only
*.log
logs/
!samples/sanitized-app.log

# OS and editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Docker
*.tar

# Credentials and keys — never commit
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519

# Grafana data (generated at runtime)
monitoring/grafana/data/
